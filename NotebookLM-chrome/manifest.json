{
  "manifest_version": 3,
  "name": "空来Ai-NotebookLM辅助器",
  "description": "定时进入指定 NotebookLM 笔记本并刷新指定来源。",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "contextMenus",
    "activeTab",
    "scripting",
    "notifications",
    "downloads",
    "bookmarks"
  ],
  "host_permissions": [
    "https://notebooklm.google.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "x_context_capture.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "空来Ai-NotebookLM辅助器",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
